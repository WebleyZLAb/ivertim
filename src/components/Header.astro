---
const navItems = [
  { href: "/usluge", label: "Usluge" },
  { href: "/projekti", label: "Projekti" },
  { href: "/proces-saradnje", label: "Proces saradnje" },
  { href: "/blog", label: "Blog" },
];
---

<header class="site-header">
  <a class="logo" href="/">Ivertim</a>
  <nav aria-label="Glavna navigacija">
    <ul>
      {
        navItems.map((item) => (
          <li>
            <a href={item.href}>{item.label}</a>
          </li>
        ))
      }
    </ul>
  </nav>
  <a class="cta" href="/kontakt">Razgovarajmo</a>
</header>

<style>
  .site-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md) var(--space-lg);
    padding: var(--space-md) var(--container-padding);
    border-bottom: var(--border-1) solid var(--border-subtle);
  }

  .logo {
    font-weight: var(--text-h6-weight);
    font-size: var(--text-h6-size);
    color: var(--text-primary);
    text-decoration: none;
  }

  nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-lg);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  nav a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--text-body-sm-size);
  }

  nav a:hover {
    color: var(--text-accent);
  }

  .cta {
    display: inline-flex;
    align-items: center;
    padding: var(--space-sm) var(--space-lg);
    background: var(--action-primary);
    color: var(--action-primary-text);
    border-radius: var(--radius-2);
    text-decoration: none;
    font-size: var(--text-label-md-size);
    font-weight: var(--text-label-md-weight);
    transition: background var(--motion-fast) var(--ease-out);
  }

  .cta:hover {
    background: var(--action-primary-hover);
    color: var(--action-primary-text);
  }

  .cta:active {
    background: var(--action-primary-active);
  }

  .cta:focus-visible {
    outline: none;
    box-shadow: var(--focus-default);
  }
</style>
