---
import { getCollection, render } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";

export async function getStaticPaths() {
  const usluge = await getCollection("usluge");
  return usluge.map((usluga) => ({
    params: { slug: usluga.id },
    props: { usluga },
  }));
}

const { usluga } = Astro.props;
const { Content } = await render(usluga);
---

<PageLayout title={usluga.data.title} description={usluga.data.description}>
  <article>
    <h1>{usluga.data.title}</h1>
    <Content />
  </article>
</PageLayout>

<style>
  h1 {
    font-size: var(--text-h1-size-fluid);
    line-height: var(--text-h1-leading);
    font-weight: var(--text-h1-weight);
  }

  article {
    max-width: var(--content-max);
  }
</style>
