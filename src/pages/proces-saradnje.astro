---
import PageLayout from "../layouts/PageLayout.astro";

const steps = [
  "Prvi razgovor",
  "Razumijevanje potreba",
  "Mjerenje prostora",
  "Prijedlog rješenja",
  "Nacrt i 3D prikaz",
  "Potvrda",
  "Proizvodnja",
  "Transport i montaža",
  "Postprodajna briga",
];
---

<PageLayout
  title="Proces saradnje"
  description="Kako izgleda saradnja sa Ivertim — od prvog razgovora do montaže."
>
  <h1>Proces saradnje</h1>
  <ol class="timeline">
    {steps.map((step) => (
      <li>{step}</li>
    ))}
  </ol>
  <p><!-- TODO: objašnjenje svakog koraka (zašto se mjeri, kada se odlučuje...) čeka copy --></p>
</PageLayout>

<style>
  h1 {
    font-size: var(--text-h1-size-fluid);
    line-height: var(--text-h1-leading);
    font-weight: var(--text-h1-weight);
  }

  .timeline {
    display: grid;
    gap: var(--space-md);
    margin: var(--space-xl) 0;
    padding-left: var(--space-lg);
  }
</style>
