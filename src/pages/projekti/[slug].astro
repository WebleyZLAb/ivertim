---
import { getCollection, render } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";

export async function getStaticPaths() {
  const projekti = await getCollection("projekti");
  return projekti.map((projekat) => ({
    params: { slug: projekat.id },
    props: { projekat },
  }));
}

const { projekat } = Astro.props;
const { Content } = await render(projekat);
---

<PageLayout title={projekat.data.title} description={projekat.data.description}>
  <article>
    <h1>{projekat.data.title}</h1>
    <Content />
  </article>
</PageLayout>

<style>
  h1 {
    font-size: var(--text-h1-size-fluid);
    line-height: var(--text-h1-leading);
    font-weight: var(--text-h1-weight);
  }

  article {
    max-width: var(--content-max);
  }
</style>
